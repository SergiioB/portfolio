---
import { getCollection } from "astro:content";

import PostCard from "../components/PostCard.astro";
import { PUBLIC_CV, SITE } from "../config/site";
import { CATEGORY_META, CATEGORY_ORDER } from "../content/categories";
import BaseLayout from "../layouts/BaseLayout.astro";
import { withBase } from "../utils/paths";

const posts = await getCollection("posts");
const publishedPosts = posts
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const latestPosts = publishedPosts.slice(0, 6);
const categoryCounts = CATEGORY_ORDER.map((category) => ({
  slug: category,
  label: CATEGORY_META[category].label,
  description: CATEGORY_META[category].description,
  count: publishedPosts.filter((post) => post.data.category.includes(category)).length,
})).filter((c) => c.count > 0);

const latestDate = publishedPosts[0]?.data.pubDate;
const publicCvHref = PUBLIC_CV.external ? PUBLIC_CV.href : withBase(PUBLIC_CV.href);
---

<BaseLayout
  title={`${SITE.author} | Linux & Virtualization Engineering Portfolio`}
  description={SITE.description}
>
  <!-- Hero Section -->
  <section class="hero">
    <h1 class="hero-title">Structured Engineering Case Studies</h1>
    <p class="hero-description">Linux & Virtualization Engineering Portfolio</p>

    <div class="hero-actions">
      {
        PUBLIC_CV.enabled && (
          <a
            href={publicCvHref}
            class="btn btn-primary"
            target={PUBLIC_CV.openInNewTab ? "_blank" : undefined}
            rel={PUBLIC_CV.openInNewTab ? "noopener noreferrer" : undefined}
          >
            {PUBLIC_CV.label}
          </a>
        )
      }
      <a
        href="https://github.com/SergiioB"
        class="btn btn-outline"
        target="_blank"
        rel="noopener noreferrer">GitHub Profile</a
      >
      <a
        href="https://www.linkedin.com/in/sergio-barrientose/"
        class="btn btn-outline"
        target="_blank"
        rel="noopener noreferrer">LinkedIn</a
      >
    </div>

    <div class="hero-stats">
      <div class="stat-item">
        <span class="stat-label">CURRENT ROLE</span>
        <span class="stat-value">{SITE.role}</span>
        <span class="stat-meta">Deutsche Pfandbriefbank AG · Madrid</span>
      </div>
      <div class="stat-item">
        <span class="stat-label">PUBLISHED CASES</span>
        <span class="stat-value">{publishedPosts.length}</span>
        <span class="stat-meta">Technical deep dives</span>
      </div>
      <div class="stat-item">
        <span class="stat-label">LAST UPDATE</span>
        <span class="stat-value">
          {
            latestDate
              ? latestDate.toLocaleDateString("en-US", {
                  month: "short",
                  day: "numeric",
                  year: "numeric",
                })
              : "—"
          }
        </span>
        <span class="stat-meta">Archive-first publishing</span>
      </div>
    </div>
  </section>

  <!-- Quick Overview -->
  <section class="section overview">
    <div class="section-header">
      <h2 class="section-title">At a Glance</h2>
      <a href={withBase("about/")} class="section-link">Full Profile →</a>
    </div>

    <div class="overview-content">
      <p class="overview-summary">{SITE.profileSummary}</p>

      <div class="overview-grid grid-auto">
        <div class="card">
          <h3 class="card-title">Linux Platform Engineering</h3>
          <p class="card-meta">RHEL lifecycle, troubleshooting, kernel tuning</p>
        </div>
        <div class="card">
          <h3 class="card-title">Automation & Governance</h3>
          <p class="card-meta">Ansible, Git workflows, IaC discipline</p>
        </div>
        <div class="card">
          <h3 class="card-title">Virtualization & Ops</h3>
          <p class="card-meta">VMware vSphere, server lifecycle, HA/DR</p>
        </div>
        <div class="card">
          <h3 class="card-title">Enterprise AI Integration</h3>
          <p class="card-meta">Azure AI Foundry, document intelligence</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Production Spotlight -->
  <section class="section spotlight" style="border-left: 4px solid var(--accent);">
    <div class="section-header">
      <h2 class="section-title" style="color: var(--accent);">Production Spotlight</h2>
      <a
        href="https://play.google.com/store/apps/details?id=com.intelliflow.finances&hl=en"
        class="section-link"
        target="_blank"
        rel="noopener noreferrer">App Store →</a
      >
    </div>

    <div class="spotlight-content">
      <span class="badge badge-accent">● Live on Google Play & Web</span>
      <h3 class="spotlight-title">📱 IntelliFlow: AI Budget Tracker</h3>
      <p class="spotlight-description">
        A production-grade personal finance application serving real users. Features an AI-powered
        financial coach, offline-first architecture, and cross-platform syncing.
      </p>
      <div class="spotlight-actions">
        <a
          href="https://play.google.com/store/apps/details?id=com.intelliflow.finances&hl=en"
          class="btn btn-primary"
          target="_blank"
          rel="noopener noreferrer"
        >
          <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor"
            ><path
              d="M3,20.5V3.5C3,2.91 3.34,2.39 3.84,2.15L13.69,12L3.84,21.85C3.34,21.6 3,21.09 3,20.5M16.81,15.12L6.05,21.34L14.54,12.85L16.81,15.12M20.16,10.81C20.5,11.08 20.75,11.5 20.75,12C20.75,12.5 20.5,12.92 20.16,13.19L17.89,16.05L15.39,12L17.89,7.95L20.16,10.81M16.81,8.88L14.54,11.15L6.05,2.66L16.81,8.88Z"
            ></path></svg
          >
          Get it on Google Play
        </a>
        <a
          href="https://intelliflow-finance.web.app/"
          class="btn btn-outline"
          target="_blank"
          rel="noopener noreferrer"
        >
          <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor"
            ><path
              d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z"
            ></path></svg
          >
          Open Web App
        </a>
      </div>
    </div>
  </section>

  <!-- Domains -->
  <section class="section domains-section">
    <div class="section-header">
      <h2 class="section-title">Domains</h2>
      <a href={withBase("archive/")} class="section-link">Browse All →</a>
    </div>

    <div class="domains-grid">
      {
        categoryCounts.map((category) => (
          <a href={withBase(`${category.slug}/`)} class="card domain-card">
            <div class="domain-header">
              <span class={`badge category-${category.slug}`}>{category.label}</span>
              <span class="domain-count">{category.count}</span>
            </div>
            <p class="domain-description">{category.description}</p>
          </a>
        ))
      }
    </div>
  </section>

  <!-- GitHub Projects -->
  <section class="section github-section">
    <div class="section-header">
      <h2 class="section-title">Open Source Projects</h2>
      <a
        href="https://github.com/SergiioB"
        class="section-link"
        target="_blank"
        rel="noopener noreferrer">View All →</a
      >
    </div>

    <div class="projects-grid">
      <a
        href="https://github.com/SergiioB/llamacpp-workbench"
        class="card project-card"
        target="_blank"
        rel="noopener noreferrer"
      >
        <h3 class="card-title">llamacpp-workbench</h3>
        <p class="card-meta">Local LLM inference workbench for RK3588 and edge devices</p>
        <span class="badge badge-accent">Rust</span>
      </a>
      <a
        href="https://github.com/SergiioB"
        class="card project-card"
        target="_blank"
        rel="noopener noreferrer"
      >
        <h3 class="card-title">IntelliFlow</h3>
        <p class="card-meta">AI-powered personal finance app with offline-first architecture</p>
        <span class="badge badge-accent">Flutter</span>
      </a>
      <a
        href="https://github.com/SergiioB"
        class="card project-card"
        target="_blank"
        rel="noopener noreferrer"
      >
        <h3 class="card-title">Ansible Collections</h3>
        <p class="card-meta">Infrastructure automation playbooks and roles</p>
        <span class="badge badge-accent">Ansible</span>
      </a>
    </div>
  </section>

  <!-- Recent Posts -->
  <section class="section" style="background: transparent; border: none; padding: 0;">
    <div class="section-header">
      <h2 class="section-title">Recent Case Studies</h2>
      <a href={withBase("archive/")} class="section-link">All Posts →</a>
    </div>

    <div class="posts-feed">
      {latestPosts.map((post) => <PostCard post={post} />)}
      {publishedPosts.length === 0 && <p class="empty-state">No posts published yet.</p>}
    </div>
  </section>
</BaseLayout>
