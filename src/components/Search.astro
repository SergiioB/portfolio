---
import { withBase } from "../utils/paths";

const searchDataUrl = withBase("search.json");
---

<div class="search-wrapper">
  <div class="search-container" id="search-container">
    <div class="search-box" id="search-box">
      <span class="search-prompt">~$</span>
      <input
        type="text"
        class="search-input"
        id="search-input"
        placeholder="grep posts..."
        autocomplete="off"
        spellcheck="false"
      />
      <span class="search-cursor" id="search-cursor">█</span>
      <kbd class="search-shortcut">Ctrl+F</kbd>
    </div>

    <div class="search-dropdown" id="search-dropdown" hidden>
      <div class="search-dropdown-header">
        <span id="search-results-count"></span>
        <button class="search-close-btn" id="search-close-btn" aria-label="Close search">×</button>
      </div>
      <div class="search-results-list" id="search-results-list"></div>
    </div>
  </div>
</div>

<script is:inline define:vars={{ searchDataUrl }}>
  (() => {
    const state =
      window.__portfolioSearchState ||
      (window.__portfolioSearchState = {
        postsData: [],
        isLoaded: false,
        pendingLoad: null,
        initPage: null,
      });

    const getElements = () => ({
      container: document.getElementById("search-container"),
      input: document.getElementById("search-input"),
      dropdown: document.getElementById("search-dropdown"),
      resultsList: document.getElementById("search-results-list"),
      resultsCount: document.getElementById("search-results-count"),
      closeBtn: document.getElementById("search-close-btn"),
      cursor: document.getElementById("search-cursor"),
    });

    const escapeHtml = (text) => {
      const div = document.createElement("div");
      div.textContent = text;
      return div.innerHTML;
    };

    const escapeRegex = (value) => value.replace(/[.*+?^${}()|[\]\\]/g, "\\$&");

    const highlightText = (text, query) => {
      const regex = new RegExp(`(${escapeRegex(query)})`, "gi");
      return escapeHtml(text).replace(regex, "<mark>$1</mark>");
    };

    const loadSearchData = () => {
      if (state.isLoaded) return Promise.resolve(state.postsData);
      if (state.pendingLoad) return state.pendingLoad;

      state.pendingLoad = fetch(searchDataUrl)
        .then((response) => response.json())
        .then((data) => {
          state.postsData = data;
          state.isLoaded = true;
          return data;
        })
        .catch((error) => {
          console.error("Search load error:", error);
          return [];
        })
        .finally(() => {
          state.pendingLoad = null;
        });

      return state.pendingLoad;
    };

    const closeSearch = () => {
      const { container, input, dropdown } = getElements();
      if (!container || !input || !dropdown) return;

      dropdown.hidden = true;
      container.classList.remove("active");
      input.blur();
    };

    const showResults = (results, query) => {
      const { dropdown, resultsCount, resultsList } = getElements();
      if (!dropdown || !resultsCount || !resultsList) return;

      resultsCount.textContent = `${results.length} result${results.length !== 1 ? "s" : ""}`;

      if (results.length === 0) {
        resultsList.innerHTML = `<div class="search-no-results">No matches found for "${escapeHtml(query)}"</div>`;
      } else {
        resultsList.innerHTML = results
          .map(
            (post) => `<a href="${post.url}" class="search-result-item" data-search-result-link>
              <div class="search-result-meta">
                <span class="search-result-category">${escapeHtml(post.category[0])}</span>
                <span class="search-result-date">${escapeHtml(post.date)}</span>
              </div>
              <h4 class="search-result-title">${highlightText(post.title, query)}</h4>
              <p class="search-result-desc">${highlightText(post.description, query)}</p>
              ${
                post.tags && post.tags.length
                  ? `<div class="search-result-tags">${post.tags
                      .map((tag) => `<span class="tag">${escapeHtml(tag)}</span>`)
                      .join("")}</div>`
                  : ""
              }
            </a>`
          )
          .join("");
      }

      dropdown.hidden = false;
    };

    const performSearch = (query) => {
      if (!state.postsData.length) return;

      const results = state.postsData.filter((post) => {
        const searchText =
          `${post.title} ${post.description} ${post.category.join(" ")} ${(post.tags || []).join(" ")}`.toLowerCase();
        return searchText.includes(query);
      });

      showResults(results, query);
    };

    state.initPage = () => {
      const { container, input, dropdown, resultsList, closeBtn, cursor } = getElements();
      if (!container || !input || !dropdown || !resultsList || !closeBtn || !cursor) return;
      if (container.dataset.searchBound === "1") return;
      container.dataset.searchBound = "1";

      input.addEventListener("focus", () => {
        container.classList.add("active");
        cursor.style.animationPlayState = "running";
        loadSearchData();

        const query = input.value.trim().toLowerCase();
        if (query.length >= 2) {
          performSearch(query);
        }
      });

      input.addEventListener("blur", () => {
        cursor.style.animationPlayState = "paused";
      });

      input.addEventListener("input", (event) => {
        const query = event.target.value.trim().toLowerCase();

        if (query.length < 2) {
          dropdown.hidden = true;
          return;
        }

        performSearch(query);
      });

      closeBtn.addEventListener("click", (event) => {
        event.stopPropagation();
        closeSearch();
      });

      resultsList.addEventListener("click", (event) => {
        if (event.target.closest("[data-search-result-link]")) {
          closeSearch();
        }
      });
    };

    if (!state.globalBound) {
      state.globalBound = true;

      document.addEventListener(
        "keydown",
        (event) => {
          const { container, input } = getElements();

          if ((event.ctrlKey || event.metaKey) && event.key === "f") {
            if (!container || !input) return;
            event.preventDefault();
            event.stopPropagation();
            loadSearchData().then(() => {
              input.focus();
              container.classList.add("active");
            });
          }

          if (event.key === "Escape") {
            closeSearch();
          }
        },
        true
      );

      document.addEventListener("click", (event) => {
        const { container } = getElements();
        if (container && !container.contains(event.target)) {
          closeSearch();
        }
      });

      document.addEventListener("astro:page-load", () => {
        state.initPage?.();
      });
    }

    state.initPage();
  })();
</script>
