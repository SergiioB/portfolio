---
// Search component for technical portfolio
---

<div class="search-wrapper">
  <div class="search-container" id="search-container">
    <div class="search-box" id="search-box">
      <span class="search-prompt">~$</span>
      <input
        type="text"
        class="search-input"
        id="search-input"
        placeholder="grep posts..."
        autocomplete="off"
        spellcheck="false"
      />
      <span class="search-cursor" id="search-cursor">█</span>
      <kbd class="search-shortcut">Ctrl+F</kbd>
    </div>

    <div class="search-dropdown" id="search-dropdown" hidden>
      <div class="search-dropdown-header">
        <span id="search-results-count"></span>
        <button class="search-close-btn" id="search-close-btn" aria-label="Close search">×</button>
      </div>
      <div class="search-results-list" id="search-results-list"></div>
    </div>
  </div>
</div>

<script is:inline>
  // Search functionality
  (function() {
    const container = document.getElementById('search-container');
    const input = document.getElementById('search-input');
    const dropdown = document.getElementById('search-dropdown');
    const resultsList = document.getElementById('search-results-list');
    const resultsCount = document.getElementById('search-results-count');
    const closeBtn = document.getElementById('search-close-btn');
    const cursor = document.getElementById('search-cursor');

    let postsData = [];
    let isLoaded = false;

    // Load search data
    function loadSearchData() {
      if (isLoaded) return Promise.resolve();
      
      return fetch('/search.json')
        .then(res => res.json())
        .then(data => {
          postsData = data;
          isLoaded = true;
        })
        .catch(err => console.error('Search load error:', err));
    }

    // Keyboard shortcut - Ctrl+F or Cmd+F for search
    document.addEventListener('keydown', function(e) {
      if ((e.ctrlKey || e.metaKey) && e.key === 'f') {
        e.preventDefault();
        e.stopPropagation();
        loadSearchData().then(() => {
          input.focus();
          container.classList.add('active');
        });
      }
      
      if (e.key === 'Escape') {
        closeSearch();
      }
    }, true);

    // Focus handling
    input.addEventListener('focus', function() {
      container.classList.add('active');
      cursor.style.animationPlayState = 'running';
      loadSearchData();
      
      if (input.value.trim().length >= 2) {
        performSearch(input.value.trim().toLowerCase());
      }
    });

    input.addEventListener('blur', function() {
      cursor.style.animationPlayState = 'paused';
    });

    // Input handling
    input.addEventListener('input', function(e) {
      const query = e.target.value.trim().toLowerCase();
      
      if (query.length < 2) {
        hideDropdown();
        return;
      }
      
      performSearch(query);
    });

    // Close button
    closeBtn.addEventListener('click', function(e) {
      e.stopPropagation();
      closeSearch();
    });

    function closeSearch() {
      dropdown.hidden = true;
      container.classList.remove('active');
      input.blur();
    }

    function hideDropdown() {
      dropdown.hidden = true;
    }

    function performSearch(query) {
      if (!postsData.length) return;

      const results = postsData.filter(function(post) {
        const searchText = (post.title + ' ' + post.description + ' ' + post.category.join(' ') + ' ' + (post.tags || []).join(' ')).toLowerCase();
        return searchText.includes(query);
      });

      showResults(results, query);
    }

    function showResults(results, query) {
      resultsCount.textContent = results.length + ' result' + (results.length !== 1 ? 's' : '');
      
      if (results.length === 0) {
        resultsList.innerHTML = '<div class="search-no-results">No matches found for "' + escapeHtml(query) + '"</div>';
      } else {
        resultsList.innerHTML = results.map(function(post) {
          return '<a href="' + post.url + '" class="search-result-item" onclick="closeSearch()">' +
            '<div class="search-result-meta">' +
              '<span class="search-result-category">' + post.category[0] + '</span>' +
              '<span class="search-result-date">' + post.date + '</span>' +
            '</div>' +
            '<h4 class="search-result-title">' + highlightText(post.title, query) + '</h4>' +
            '<p class="search-result-desc">' + highlightText(post.description, query) + '</p>' +
            (post.tags && post.tags.length ? '<div class="search-result-tags">' + post.tags.map(function(t) { return '<span class="tag">' + t + '</span>'; }).join('') + '</div>' : '') +
          '</a>';
        }).join('');
      }
      
      dropdown.hidden = false;
    }

    function highlightText(text, query) {
      const regex = new RegExp('(' + escapeRegex(query) + ')', 'gi');
      return escapeHtml(text).replace(regex, '<mark>$1</mark>');
    }

    function escapeHtml(text) {
      const div = document.createElement('div');
      div.textContent = text;
      return div.innerHTML;
    }

    function escapeRegex(string) {
      return string.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
    }

    // Close on click outside
    document.addEventListener('click', function(e) {
      if (!container.contains(e.target)) {
        closeSearch();
      }
    });
  })();
</script>
