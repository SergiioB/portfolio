---
// Search component for technical portfolio
---

<div class="search-container" data-search-container>
  <div class="search-box">
    <span class="search-prompt">~$</span>
    <input
      type="text"
      class="search-input"
      placeholder="grep posts... [type to search]"
      data-search-input
      autocomplete="off"
    />
    <span class="search-cursor">█</span>
    <kbd class="search-shortcut">Ctrl+K</kbd>
  </div>

  <div class="search-results" data-search-results hidden>
    <div class="results-header">
      <span class="results-count" data-results-count></span>
      <button class="results-close" data-search-close>×</button>
    </div>
    <div class="results-list" data-results-list></div>
  </div>
</div>

<script>
  (function () {
    const container = document.querySelector("[data-search-container]");
    const input = document.querySelector("[data-search-input]");
    const resultsContainer = document.querySelector("[data-search-results]");
    const resultsList = document.querySelector("[data-results-list]");
    const resultsCount = document.querySelector("[data-results-count]");
    const closeBtn = document.querySelector("[data-search-close]");

    // Fetch all posts data
    let postsData = [];

    async function loadPosts() {
      try {
        const response = await fetch("/search.json");
        postsData = await response.json();
      } catch (e) {
        console.error("Failed to load search data:", e);
      }
    }

    // Initialize
    loadPosts();

    // Keyboard shortcut
    document.addEventListener("keydown", (e) => {
      if ((e.metaKey || e.ctrlKey) && e.key === "k") {
        e.preventDefault();
        input.focus();
      }
      if (e.key === "Escape") {
        closeSearch();
      }
    });

    // Input handling
    input.addEventListener("input", (e) => {
      const query = e.target.value.trim().toLowerCase();
      if (query.length < 2) {
        closeSearch();
        return;
      }
      performSearch(query);
    });

    input.addEventListener("focus", () => {
      container.classList.add("active");
      if (input.value.trim().length >= 2) {
        performSearch(input.value.trim().toLowerCase());
      }
    });

    closeBtn.addEventListener("click", closeSearch);

    function closeSearch() {
      resultsContainer.hidden = true;
      container.classList.remove("active");
    }

    function performSearch(query) {
      const results = postsData.filter((post) => {
        const searchText =
          `${post.title} ${post.description} ${post.category.join(" ")} ${post.tags?.join(" ") || ""}`.toLowerCase();
        return searchText.includes(query);
      });

      displayResults(results, query);
    }

    function displayResults(results, query) {
      if (results.length === 0) {
        resultsList.innerHTML = '<div class="no-results">No matches found</div>';
        resultsCount.textContent = "0 results";
      } else {
        resultsCount.textContent = `${results.length} result${results.length !== 1 ? "s" : ""}`;
        resultsList.innerHTML = results
          .map(
            (post) => `
          <a href="${post.url}" class="result-item">
            <div class="result-meta">
              <span class="result-category">${post.category[0]}</span>
              <span class="result-date">${post.date}</span>
            </div>
            <h4 class="result-title">${highlightMatch(post.title, query)}</h4>
            <p class="result-excerpt">${highlightMatch(post.description, query)}</p>
            ${post.tags ? `<div class="result-tags">${post.tags.map((tag) => `<span class="tag">${tag}</span>`).join("")}</div>` : ""}
          </a>
        `
          )
          .join("");
      }
      resultsContainer.hidden = false;
    }

    function highlightMatch(text, query) {
      const regex = new RegExp(`(${escapeRegex(query)})`, "gi");
      return text.replace(regex, "<mark>$1</mark>");
    }

    function escapeRegex(string) {
      return string.replace(/[.*+?^${}()|[\]\\]/g, "\\$&");
    }

    // Close on click outside
    document.addEventListener("click", (e) => {
      if (!container.contains(e.target)) {
        closeSearch();
      }
    });
  })();
</script>
