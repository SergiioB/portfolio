<div
  class="audience-floating-island"
  data-audience-switch
>
  <div class="audience-toggle-island" role="tablist" aria-label="Audience mode selector">
    <div style="display: flex; align-items: center; justify-content: space-between; gap: 1rem;">
      <span class="audience-label" style="font-family: var(--font-mono); font-size: 0.75rem; font-weight: bold; letter-spacing: 0.05em; text-transform: uppercase; color: var(--text-soft); white-space: nowrap;">
        Viewing As:
      </span>
      <div style="display: flex; background: rgba(0,0,0,0.5); border-radius: 9999px; padding: 0.2rem; border: 1px solid rgba(255,255,255,0.1);">
        <button
          type="button"
          class="island-btn active"
          data-audience-mode="recruiter"
          aria-selected="true"
          role="tab"
          data-i18n="audience.recruiterMode"
        >
          Recruiter
        </button>
        <button
          type="button"
          class="island-btn"
          data-audience-mode="engineer"
          aria-selected="false"
          role="tab"
          data-i18n="audience.engineerMode"
        >
          Engineer
        </button>
      </div>
    </div>
  </div>
</div>

<style>
  .audience-floating-island {
    position: fixed;
    bottom: 24px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 1000;
    pointer-events: auto;
    animation: slideUpFade 0.7s cubic-bezier(0.16, 1, 0.3, 1) 0.5s both;
  }

  .audience-toggle-island {
    background: rgba(22, 27, 34, 0.85);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255,255,255,0.15);
    padding: 0.5rem 0.5rem 0.5rem 1rem;
    border-radius: 9999px;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4), 0 0 0 1px rgba(255,255,255,0.05) inset;
  }

  .island-btn {
    border: none;
    background: transparent;
    color: var(--text-muted);
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: bold;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.4rem 1rem;
    border-radius: 9999px;
    cursor: pointer;
    transition: all 0.25s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .island-btn.active {
    background: var(--surface-soft);
    color: var(--text-strong);
    box-shadow: 0 2px 8px rgba(0,0,0,0.2), inset 0 1px 0 rgba(255,255,255,0.1);
    border: 1px solid rgba(255,255,255,0.1);
  }

  .island-btn:hover:not(.active) {
    color: var(--text-soft);
  }

  @keyframes slideUpFade {
    0% {
      opacity: 0;
      transform: translate(-50%, 20px) scale(0.95);
    }
    100% {
      opacity: 1;
      transform: translate(-50%, 0) scale(1);
    }
  }
</style>
<!-- Button click handlers and state management are centralised in nav.js
     (applyAudienceMode / initAudienceButtons) to avoid Astro module-timing
     race conditions that previously caused the toggle to be unresponsive. -->
