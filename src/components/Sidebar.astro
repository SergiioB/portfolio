---
import { getCollection } from "astro:content";

import { PUBLIC_CV, PUBLIC_LINKS, SITE } from "../config/site";
import { CATEGORY_META, CATEGORY_ORDER, categoryMatches } from "../content/categories";
import { withBase } from "../utils/paths";

const posts = await getCollection("posts");
const publishedPosts = posts.filter((post) => !post.data.draft);

const categoryCounts = CATEGORY_ORDER.map((category) => ({
  slug: category,
  label: CATEGORY_META[category].label,
  count: publishedPosts.filter((post) => categoryMatches(post.data.category, category)).length,
})).filter((cat) => cat.count > 0);

const currentPath = Astro.url.pathname;

function isActive(path: string): boolean {
  if (path === withBase()) {
    return (
      currentPath === withBase() || currentPath === "/portfolio/" || currentPath === "/portfolio"
    );
  }
  return currentPath.startsWith(path);
}

const publicCvHref = PUBLIC_CV.external ? PUBLIC_CV.href : withBase(PUBLIC_CV.href);
const publicCvHrefEs = PUBLIC_CV.external ? PUBLIC_CV.hrefEs : withBase(PUBLIC_CV.hrefEs);
---

<aside class="sidebar" id="site-sidebar" data-sidebar>
  <div class="sidebar-header">
    <a href={withBase()} class="site-brand">
      <span class="brand-name" data-i18n="site.brand">{SITE.brand}</span>
      <span class="brand-role" data-i18n="site.role">{SITE.role}</span>
    </a>
    <p class="sidebar-summary" data-i18n="site.profileSummary">{SITE.profileSummary}</p>
    <div class="sidebar-language-switcher">
      <span class="sidebar-language-label" data-i18n="lang.label">Language</span>
      <div
        class="lang-switcher-pill"
        role="group"
        aria-label="Language"
        data-i18n-label="lang.label"
      >
        <button
          type="button"
          class="lang-option-btn"
          data-lang-option="en"
          data-i18n-label="lang.english"
          aria-pressed="true"
        >
          EN
        </button>
        <button
          type="button"
          class="lang-option-btn"
          data-lang-option="es"
          data-i18n-label="lang.spanish"
          aria-pressed="false"
        >
          ES
        </button>
      </div>
    </div>
  </div>

  <nav class="sidebar-nav" aria-label="Primary navigation">
    <div class="nav-section">
      <div class="nav-section-title" data-i18n="nav.portfolio">Portfolio</div>
      <ul class="nav-list">
        <li class="nav-item">
          <a
            href={withBase()}
            class:list={["nav-link", { active: isActive(withBase()) }]}
            data-i18n="nav.home">Home</a
          >
        </li>
        <li class="nav-item">
          <a
            href={withBase("archive/")}
            class:list={["nav-link", { active: isActive(withBase("archive/")) }]}
            data-i18n="nav.archive">Archive</a
          >
        </li>
        <li class="nav-item">
          <a
            href={withBase("about/")}
            class:list={["nav-link", { active: isActive(withBase("about/")) }]}
            data-i18n="nav.about">About + CV</a
          >
        </li>
      </ul>
    </div>

    <div class="nav-section">
      <div class="nav-section-title" data-i18n="nav.domains">Domains</div>
      <ul class="nav-list">
        {
          categoryCounts.map((cat) => (
            <li class="nav-item">
              <a href={withBase(`${cat.slug}/`)} class={`nav-link category-${cat.slug}`}>
                <span class="nav-link-label" data-i18n={`cat.${cat.slug}`}>
                  {cat.label}
                </span>
                <span class="nav-link-count">{cat.count}</span>
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </nav>

  <div class="sidebar-footer">
    {
      PUBLIC_CV.enabled && (
        <a
          href={publicCvHref}
          data-href-en={publicCvHref}
          data-href-es={publicCvHrefEs}
          class="btn btn-primary"
          target={PUBLIC_CV.openInNewTab ? "_blank" : undefined}
          rel={PUBLIC_CV.openInNewTab ? "noopener noreferrer" : undefined}
          data-i18n="about.cvLabel"
        >
          {PUBLIC_CV.label}
        </a>
      )
    }
    <div class="sidebar-links">
      {
        PUBLIC_LINKS.map((link) => (
          <a
            href={link.href}
            class="sidebar-link"
            target="_blank"
            rel="noopener noreferrer"
            data-i18n={link.label === "LinkedIn" ? "link.linkedin" : undefined}
          >
            {link.label}
          </a>
        ))
      }
    </div>
  </div>
</aside>

<header class="mobile-header">
  <button
    class="menu-toggle"
    type="button"
    data-menu-toggle
    aria-label="Toggle navigation"
    data-i18n-label="nav.menuLabel"
  >
    <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"
      ><path d="M3 18h18v-2H3v2zm0-5h18v-2H3v2zm0-7v2h18V6H3z"></path></svg
    >
  </button>
  <a href={withBase()} class="mobile-brand" data-i18n="site.brand">{SITE.brand}</a>
</header>
